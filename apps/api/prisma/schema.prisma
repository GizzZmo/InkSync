generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  CLIENT
  ARTIST
  STUDIO_OWNER
  ADMIN
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
  NO_SHOW
}

enum PaymentStatus {
  PENDING
  PAID
  REFUNDED
  FAILED
}

enum TattooStyle {
  TRADITIONAL
  NEO_TRADITIONAL
  REALISM
  WATERCOLOR
  BLACKWORK
  TRIBAL
  JAPANESE
  GEOMETRIC
  MINIMALIST
  ILLUSTRATIVE
  OTHER
}

enum WaiverStatus {
  DRAFT
  SIGNED
  EXPIRED
}

enum MessageType {
  TEXT
  IMAGE
  SYSTEM
}

model User {
  id                String    @id @default(uuid())
  email             String    @unique
  passwordHash      String?
  firstName         String
  lastName          String
  phone             String?
  avatarUrl         String?
  role              UserRole  @default(CLIENT)
  emailVerified     Boolean   @default(false)
  emailVerifyToken  String?
  passwordResetToken String?
  passwordResetExpiry DateTime?
  refreshTokens     RefreshToken[]
  artistProfile     ArtistProfile?
  clientAppointments Appointment[] @relation("ClientAppointments")
  sentMessages      Message[]
  notificationPrefs NotificationPreference?
  googleCalendarToken GoogleCalendarToken?
  ownedStudios      Studio[]  @relation("StudioOwner")
  flashPurchases    FlashPurchase[] @relation("FlashPurchases")
  reviews           Review[]  @relation("ClientReviews")
  webhooks          Webhook[] @relation("UserWebhooks")
  apiKeys           ApiKey[]  @relation("UserApiKeys")
  ownedEnterprises  EnterpriseAccount[] @relation("EnterpriseOwner")
  organizedEvents   Event[]   @relation("EventOrganizer")
  courseEnrollments CourseEnrollment[] @relation("CourseEnrollments")
  userLocale        UserLocale?
  contentReports    ContentReport[] @relation("ContentReports")
  dataExportRequests DataExportRequest[] @relation("DataExportRequests")
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([email])
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  isRevoked Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([token])
}

model ArtistProfile {
  id                String    @id @default(uuid())
  userId            String    @unique
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  studioId          String?
  studio            Studio?   @relation(fields: [studioId], references: [id])
  bio               String    @default("")
  styles            TattooStyle[]
  hourlyRate        Decimal?
  minimumDeposit    Decimal?
  depositPercentage Decimal?  @default(20)
  city              String    @default("")
  state             String    @default("")
  country           String    @default("US")
  latitude          Float?
  longitude         Float?
  instagramHandle   String?
  tiktokHandle      String?
  websiteUrl        String?
  yearsExperience   Int?
  isAvailable       Boolean   @default(true)
  stripeConnectId   String?
  stripeConnectStatus String? 
  portfolioImages   PortfolioImage[]
  appointments      Appointment[] @relation("ArtistAppointments")
  availability      Availability[]
  blockedDates      BlockedDate[]
  waiverTemplates   WaiverTemplate[]
  aftercares        Aftercare[]
  residencies       ArtistResidency[]
  flashDesigns      FlashDesign[]
  reviews           Review[]
  blogPosts         BlogPost[]
  apprenticeships   ApprenticeshipListing[]
  courses           Course[]
  badges            ArtistBadge[]
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([userId])
  @@index([studioId])
}

model PortfolioImage {
  id           String      @id @default(uuid())
  artistId     String
  artist       ArtistProfile @relation(fields: [artistId], references: [id], onDelete: Cascade)
  url          String
  thumbnailUrl String?
  s3Key        String
  style        TattooStyle
  title        String?
  description  String?
  isPublic     Boolean     @default(true)
  sortOrder    Int         @default(0)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@index([artistId])
  @@index([style])
}

model Availability {
  id        String        @id @default(uuid())
  artistId  String
  artist    ArtistProfile @relation(fields: [artistId], references: [id], onDelete: Cascade)
  dayOfWeek Int           // 0=Sun, 6=Sat
  startTime String        // HH:mm
  endTime   String        // HH:mm
  isActive  Boolean       @default(true)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@unique([artistId, dayOfWeek])
  @@index([artistId])
}

model BlockedDate {
  id        String        @id @default(uuid())
  artistId  String
  artist    ArtistProfile @relation(fields: [artistId], references: [id], onDelete: Cascade)
  date      DateTime
  reason    String?
  createdAt DateTime      @default(now())

  @@index([artistId])
  @@index([date])
}

model Appointment {
  id                    String            @id @default(uuid())
  clientId              String
  client                User              @relation("ClientAppointments", fields: [clientId], references: [id])
  artistId              String
  artist                ArtistProfile     @relation("ArtistAppointments", fields: [artistId], references: [id])
  studioId              String?
  studio                Studio?           @relation(fields: [studioId], references: [id])
  startTime             DateTime
  endTime               DateTime
  status                AppointmentStatus @default(PENDING)
  serviceType           String
  description           String?
  estimatedHours        Decimal?
  depositAmount         Decimal?
  depositPaid           Boolean           @default(false)
  totalAmount           Decimal?
  paymentStatus         PaymentStatus     @default(PENDING)
  googleCalendarEventId String?
  notes                 String?
  cancelReason          String?
  cancelledAt           DateTime?
  confirmedAt           DateTime?
  completedAt           DateTime?
  payments              Payment[]
  waiver                Waiver?
  aftercare             Aftercare?
  chatRoom              ChatRoom?
  reminders             Reminder[]
  review                Review?
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt

  @@index([clientId])
  @@index([artistId])
  @@index([status])
  @@index([startTime])
}

model WaiverTemplate {
  id        String        @id @default(uuid())
  artistId  String
  artist    ArtistProfile @relation(fields: [artistId], references: [id], onDelete: Cascade)
  title     String
  content   String
  version   Int           @default(1)
  isActive  Boolean       @default(true)
  waivers   Waiver[]
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@index([artistId])
}

model Waiver {
  id             String        @id @default(uuid())
  appointmentId  String        @unique
  appointment    Appointment   @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  templateId     String
  template       WaiverTemplate @relation(fields: [templateId], references: [id])
  clientId       String
  signatureData  String?       // base64 PNG
  medicalHistory Json?
  signedAt       DateTime?
  status         WaiverStatus  @default(DRAFT)
  pdfS3Key       String?
  pdfUrl         String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([appointmentId])
  @@index([clientId])
}

model Payment {
  id                     String        @id @default(uuid())
  appointmentId          String
  appointment            Appointment   @relation(fields: [appointmentId], references: [id])
  amount                 Decimal
  currency               String        @default("usd")
  status                 PaymentStatus @default(PENDING)
  stripePaymentIntentId  String?       @unique
  stripeChargeId         String?
  stripeTransferId       String?
  refundId               String?
  refundAmount           Decimal?
  refundReason           String?
  metadata               Json?
  createdAt              DateTime      @default(now())
  updatedAt              DateTime      @updatedAt

  @@index([appointmentId])
  @@index([stripePaymentIntentId])
}

model GoogleCalendarToken {
  id           String   @id @default(uuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken  String
  refreshToken String
  expiresAt    DateTime
  calendarId   String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model ChatRoom {
  id            String      @id @default(uuid())
  appointmentId String      @unique
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  messages      Message[]
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model Message {
  id        String      @id @default(uuid())
  roomId    String
  room      ChatRoom    @relation(fields: [roomId], references: [id], onDelete: Cascade)
  senderId  String
  sender    User        @relation(fields: [senderId], references: [id])
  content   String
  type      MessageType @default(TEXT)
  mediaUrl  String?
  mediaS3Key String?
  readAt    DateTime?
  createdAt DateTime    @default(now())

  @@index([roomId])
  @@index([senderId])
  @@index([createdAt])
}

model NotificationPreference {
  id                   String  @id @default(uuid())
  userId               String  @unique
  user                 User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  emailEnabled         Boolean @default(true)
  smsEnabled           Boolean @default(true)
  pushEnabled          Boolean @default(true)
  appointmentReminders Boolean @default(true)
  marketingEmails      Boolean @default(false)
  aftercareReminders   Boolean @default(true)
  paymentNotifications Boolean @default(true)
  fcmToken             String?
  updatedAt            DateTime @updatedAt
}

model Reminder {
  id            String      @id @default(uuid())
  appointmentId String
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  type          String      // 'SMS' | 'EMAIL' | 'PUSH'
  scheduledAt   DateTime
  sentAt        DateTime?
  message       String
  status        String      @default("PENDING")
  createdAt     DateTime    @default(now())

  @@index([appointmentId])
  @@index([scheduledAt])
  @@index([status])
}

model Aftercare {
  id            String             @id @default(uuid())
  appointmentId String             @unique
  appointment   Appointment        @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  artistId      String
  artist        ArtistProfile      @relation(fields: [artistId], references: [id])
  instructions  String
  milestones    AftercareMilestone[]
  photos        AftercarePhoto[]
  products      AftercareProduct[]
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  @@index([appointmentId])
  @@index([artistId])
}

model AftercareMilestone {
  id          String    @id @default(uuid())
  aftercareId String
  aftercare   Aftercare @relation(fields: [aftercareId], references: [id], onDelete: Cascade)
  dayNumber   Int
  title       String
  instructions String
  completed   Boolean   @default(false)
  completedAt DateTime?
  createdAt   DateTime  @default(now())

  @@index([aftercareId])
}

model AftercarePhoto {
  id            String    @id @default(uuid())
  aftercareId   String
  aftercare     Aftercare @relation(fields: [aftercareId], references: [id], onDelete: Cascade)
  url           String
  s3Key         String
  dayNumber     Int
  artistComment String?
  uploadedAt    DateTime  @default(now())

  @@index([aftercareId])
}

model AftercareProduct {
  id          String    @id @default(uuid())
  aftercareId String
  aftercare   Aftercare @relation(fields: [aftercareId], references: [id], onDelete: Cascade)
  name        String
  description String?
  affiliateUrl String?
  createdAt   DateTime  @default(now())
}

model Studio {
  id          String          @id @default(uuid())
  ownerId     String
  owner       User            @relation("StudioOwner", fields: [ownerId], references: [id])
  name        String
  description String?
  address     String
  city        String
  state       String
  country     String          @default("US")
  latitude    Float?
  longitude   Float?
  phone       String?
  email       String?
  websiteUrl  String?
  logoUrl     String?
  logoS3Key   String?
  isActive    Boolean         @default(true)
  artists     ArtistProfile[]
  appointments Appointment[]
  inventory   InventoryItem[]
  residencies ArtistResidency[]
  enterpriseMemberships EnterpriseMembership[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([ownerId])
}

model InventoryItem {
  id                String   @id @default(uuid())
  studioId          String
  studio            Studio   @relation(fields: [studioId], references: [id], onDelete: Cascade)
  name              String
  category          String
  quantity          Int      @default(0)
  lowStockThreshold Int      @default(5)
  unit              String   @default("unit")
  costPerUnit       Decimal?
  supplier          String?
  notes             String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([studioId])
  @@index([category])
}

model ArtistResidency {
  id          String        @id @default(uuid())
  artistId    String
  artist      ArtistProfile @relation(fields: [artistId], references: [id], onDelete: Cascade)
  studioId    String
  studio      Studio        @relation(fields: [studioId], references: [id], onDelete: Cascade)
  startDate   DateTime
  endDate     DateTime?
  isActive    Boolean       @default(true)
  announcement String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([artistId])
  @@index([studioId])
  @@index([startDate])
}

enum FlashDesignStatus {
  AVAILABLE
  SOLD
  RESERVED
}

model FlashDesign {
  id           String            @id @default(uuid())
  artistId     String
  artist       ArtistProfile     @relation(fields: [artistId], references: [id], onDelete: Cascade)
  title        String
  description  String?
  imageUrl     String
  imageS3Key   String
  price        Decimal
  style        TattooStyle
  status       FlashDesignStatus @default(AVAILABLE)
  licensingTerms String?
  purchases    FlashPurchase[]
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  @@index([artistId])
  @@index([style])
  @@index([status])
}

model FlashPurchase {
  id            String      @id @default(uuid())
  designId      String
  design        FlashDesign @relation(fields: [designId], references: [id])
  clientId      String
  client        User        @relation("FlashPurchases", fields: [clientId], references: [id])
  amount        Decimal
  stripePaymentIntentId String? @unique
  purchasedAt   DateTime    @default(now())

  @@index([designId])
  @@index([clientId])
}

model Review {
  id            String         @id @default(uuid())
  appointmentId String         @unique
  appointment   Appointment    @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  artistId      String
  artist        ArtistProfile  @relation(fields: [artistId], references: [id])
  clientId      String
  client        User           @relation("ClientReviews", fields: [clientId], references: [id])
  rating        Int
  content       String?
  artistResponse String?
  artistRespondedAt DateTime?
  isModerated   Boolean        @default(false)
  photos        ReviewPhoto[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([artistId])
  @@index([clientId])
  @@index([rating])
}

model ReviewPhoto {
  id        String   @id @default(uuid())
  reviewId  String
  review    Review   @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  url       String
  s3Key     String
  createdAt DateTime @default(now())

  @@index([reviewId])
}

model Webhook {
  id        String            @id @default(uuid())
  userId    String
  user      User              @relation("UserWebhooks", fields: [userId], references: [id], onDelete: Cascade)
  url       String
  secret    String
  events    String[]
  isActive  Boolean           @default(true)
  deliveries WebhookDelivery[]
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  @@index([userId])
}

model WebhookDelivery {
  id          String   @id @default(uuid())
  webhookId   String
  webhook     Webhook  @relation(fields: [webhookId], references: [id], onDelete: Cascade)
  event       String
  payload     Json
  responseStatus Int?
  responseBody   String?
  success     Boolean  @default(false)
  attemptedAt DateTime @default(now())

  @@index([webhookId])
  @@index([event])
}

model ApiKey {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation("UserApiKeys", fields: [userId], references: [id], onDelete: Cascade)
  name        String
  keyHash     String   @unique
  keyPrefix   String
  lastUsedAt  DateTime?
  expiresAt   DateTime?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([keyHash])
}

// ─────────────────────────────────────────────
// Phase 5.1 – Enterprise & Chains
// ─────────────────────────────────────────────

model EnterpriseAccount {
  id             String               @id @default(uuid())
  ownerId        String
  owner          User                 @relation("EnterpriseOwner", fields: [ownerId], references: [id])
  name           String
  slug           String               @unique
  tier           String               @default("enterprise") // enterprise | franchise
  isActive       Boolean              @default(true)
  brand          EnterpriseBrand?
  members        EnterpriseMembership[]
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  @@index([ownerId])
  @@index([slug])
}

model EnterpriseBrand {
  id                String            @id @default(uuid())
  enterpriseId      String            @unique
  enterprise        EnterpriseAccount @relation(fields: [enterpriseId], references: [id], onDelete: Cascade)
  logoUrl           String?
  logoS3Key         String?
  primaryColor      String?
  secondaryColor    String?
  fontFamily        String?
  serviceMenu       Json?             // array of { name, price, durationMinutes }
  depositPolicy     String?
  cancellationPolicy String?
  widgetEnabled     Boolean           @default(false)
  widgetOrigins     String[]          // allowed CORS origins for embed widget
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
}

model EnterpriseMembership {
  id           String            @id @default(uuid())
  enterpriseId String
  enterprise   EnterpriseAccount @relation(fields: [enterpriseId], references: [id], onDelete: Cascade)
  studioId     String
  studio       Studio            @relation(fields: [studioId], references: [id], onDelete: Cascade)
  role         String            @default("member") // owner | admin | member
  joinedAt     DateTime          @default(now())

  @@unique([enterpriseId, studioId])
  @@index([enterpriseId])
  @@index([studioId])
}

// ─────────────────────────────────────────────
// Phase 5.2 – Community & Education
// ─────────────────────────────────────────────

enum BlogPostStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model BlogPost {
  id          String         @id @default(uuid())
  authorId    String
  author      ArtistProfile  @relation(fields: [authorId], references: [id], onDelete: Cascade)
  title       String
  slug        String         @unique
  summary     String?
  content     String
  coverImageUrl String?
  coverS3Key  String?
  tags        String[]
  status      BlogPostStatus @default(DRAFT)
  publishedAt DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([authorId])
  @@index([status])
  @@index([publishedAt])
}

enum EventType {
  CONVENTION
  EXPO
  WORKSHOP
  GUEST_SPOT
  OTHER
}

model Event {
  id          String    @id @default(uuid())
  organizerId String
  organizer   User      @relation("EventOrganizer", fields: [organizerId], references: [id])
  title       String
  description String?
  eventType   EventType @default(CONVENTION)
  city        String
  state       String?
  country     String    @default("US")
  venue       String?
  address     String?
  startDate   DateTime
  endDate     DateTime
  websiteUrl  String?
  imageUrl    String?
  imageS3Key  String?
  isPublished Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([organizerId])
  @@index([startDate])
  @@index([eventType])
}

model ApprenticeshipListing {
  id           String        @id @default(uuid())
  artistId     String
  artist       ArtistProfile @relation(fields: [artistId], references: [id], onDelete: Cascade)
  title        String
  description  String
  requirements String?
  duration     String?       // e.g. "6 months", "1 year"
  isPaid       Boolean       @default(false)
  compensation String?
  city         String
  state        String?
  country      String        @default("US")
  isOpen       Boolean       @default(true)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([artistId])
  @@index([isOpen])
}

enum CourseStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model Course {
  id           String           @id @default(uuid())
  instructorId String
  instructor   ArtistProfile    @relation(fields: [instructorId], references: [id], onDelete: Cascade)
  title        String
  description  String
  coverImageUrl String?
  coverS3Key   String?
  price        Decimal          @default(0)
  isFree       Boolean          @default(false)
  tags         String[]
  status       CourseStatus     @default(DRAFT)
  publishedAt  DateTime?
  lessons      CourseLesson[]
  enrollments  CourseEnrollment[]
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@index([instructorId])
  @@index([status])
}

model CourseLesson {
  id          String   @id @default(uuid())
  courseId    String
  course      Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  title       String
  content     String
  videoUrl    String?
  sortOrder   Int      @default(0)
  durationMin Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([courseId])
}

model CourseEnrollment {
  id          String   @id @default(uuid())
  courseId    String
  course      Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  userId      String
  user        User     @relation("CourseEnrollments", fields: [userId], references: [id], onDelete: Cascade)
  completedAt DateTime?
  enrolledAt  DateTime @default(now())

  @@unique([courseId, userId])
  @@index([courseId])
  @@index([userId])
}

// ─────────────────────────────────────────────
// Phase 5.3 – Internationalization
// ─────────────────────────────────────────────

model UserLocale {
  id           String   @id @default(uuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  language     String   @default("en") // BCP-47 tag: en, es, de, fr, pt, ja
  currency     String   @default("USD") // ISO 4217
  timezone     String   @default("UTC")
  rtlEnabled   Boolean  @default(false)
  updatedAt    DateTime @updatedAt
}

// ─────────────────────────────────────────────
// Phase 5.4 – Platform Health & Governance
// ─────────────────────────────────────────────

enum ReportTargetType {
  REVIEW
  BLOG_POST
  ARTIST_PROFILE
  MESSAGE
  FLASH_DESIGN
}

enum ReportStatus {
  PENDING
  REVIEWED
  RESOLVED
  DISMISSED
}

model ContentReport {
  id           String           @id @default(uuid())
  reporterId   String
  reporter     User             @relation("ContentReports", fields: [reporterId], references: [id])
  targetType   ReportTargetType
  targetId     String
  reason       String
  details      String?
  status       ReportStatus     @default(PENDING)
  reviewedBy   String?
  reviewedAt   DateTime?
  resolution   String?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@index([reporterId])
  @@index([targetType, targetId])
  @@index([status])
}

enum BadgeType {
  VERIFIED_ARTIST
  TOP_RATED
  FEATURED
  SAFETY_TRAINED
  APPRENTICE_CERTIFIED
}

enum BadgeStatus {
  PENDING
  APPROVED
  REJECTED
  REVOKED
}

model ArtistBadge {
  id          String        @id @default(uuid())
  artistId    String
  artist      ArtistProfile @relation(fields: [artistId], references: [id], onDelete: Cascade)
  badgeType   BadgeType
  status      BadgeStatus   @default(PENDING)
  issuedAt    DateTime?
  expiresAt   DateTime?
  notes       String?
  reviewedBy  String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@unique([artistId, badgeType])
  @@index([artistId])
  @@index([status])
}

enum DataExportStatus {
  REQUESTED
  PROCESSING
  READY
  DOWNLOADED
  EXPIRED
}

model DataExportRequest {
  id            String           @id @default(uuid())
  userId        String
  user          User             @relation("DataExportRequests", fields: [userId], references: [id], onDelete: Cascade)
  status        DataExportStatus @default(REQUESTED)
  s3Key         String?
  downloadUrl   String?
  expiresAt     DateTime?
  requestedAt   DateTime         @default(now())
  completedAt   DateTime?

  @@index([userId])
  @@index([status])
}
